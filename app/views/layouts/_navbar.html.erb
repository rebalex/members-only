<header>
  <div class='container'>
    <nav>
      <ul class = "nav">
        <li><%= link_to "Users", users_path, class: 'nav-link' %></li>
        <li><%= link_to "Posts", posts_path, class: 'nav-link' %></li>
        <% if user_signed_in? %>
          <li><%= link_to "Profile", edit_user_registration_path, class: 'nav-link' %></li>
          <li><%= link_to "New post", new_post_path, class: 'nav-link' %></li>
          <li><%= button_to "Log out", destroy_user_session_path, method: :delete, class: 'nav-link' %></li>
         <% else %>
          <li><%= link_to "Log in", new_user_session_path, class: 'nav-link' %></li>
          <li><%= link_to "Sign up", new_user_registration_path, class: 'nav-link' %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
  